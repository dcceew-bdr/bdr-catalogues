        reg:status        reg:statusStable;
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "value of observable property";
                            sh:class        tern:Parameter;
                            sh:description  "The parameter value of the observable property.";
                            sh:maxCount     1;
                            sh:message      "A `tern:ObservableProperty` _MUST_ have exactly 1 `rdf:value` predicate with a value of type `tern:Parameter`.";
                            sh:minCount     1;
                            sh:name         "rdf:value";
