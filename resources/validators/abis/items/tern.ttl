        sh:path           tern:locationProcedure .

tern-shapes:  rdf:type      owl:Ontology;
        rdfs:comment        "SHACL Shapes for the TERN Ontology. The version number of this SHACL file is kept in sync with the main TERN Ontology";
        rdfs:label          "TERN Ontology Shapes";
        owl:imports         <http://www.opengis.net/ont/geosparql>;
        owl:imports         <http://datashapes.org/dash>;
        owl:imports         <http://www.w3.org/2004/02/skos/core>;
        owl:imports         tern:;
        owl:imports         sh:;
        owl:versionIRI      tern-shapes:0.8.0;
        owl:versionInfo     "0.8.0";
        sdo:codeRepository  "https://github.com/ternaustralia/ontology_tern"^^xsd:anyURI;
        sdo:dateModified    "2026-04-07"^^xsd:date;
        sdo:hasPart         tern-shapes:ObservationCollection-observedProperty;
        sdo:hasPart         tern-shapes:tern-collaborator;
        sdo:hasPart         tern-shapes:Distribution;
        sdo:hasPart         tern-shapes:tern-calibrationOffset;
        sdo:hasPart         tern-shapes:tern-calibrationReferenceResult;
        sdo:hasPart         tern-shapes:Taxon-taxonConceptID;
        sdo:hasPart         tern-shapes:RDFDataset-creator;
        sdo:hasPart         tern-shapes:Taxon-nameAccordingTo;
        sdo:hasPart         tern-shapes:Taxon-parentNameUsage;
        sdo:hasPart         tern-shapes:IRI;
        sdo:hasPart         tern-shapes:tern-undertakenBefore;
        sdo:hasPart         tern-shapes:Observation-hasResult;
        sdo:hasPart         tern-shapes:tern-funder;
        sdo:hasPart         tern-shapes:tern-samplingType;
        sdo:hasPart         tern-shapes:RDFDataset-subject;
        sdo:hasPart         tern-shapes:Sampling;
        sdo:hasPart         tern-shapes:Platform;
        sdo:hasPart         tern-shapes:tern-producer;
        sdo:hasPart         tern-shapes:Taxon-verbatimTaxonRank;
        sdo:hasPart         tern-shapes:Sampler-implements;
        sdo:hasPart         tern-shapes:tern-isAttributeOf;
        sdo:hasPart         tern-shapes:time-hasEnd;
        sdo:hasPart         tern-shapes:tern-verticalExtent;
        sdo:hasPart         tern-shapes:Float-value;
        sdo:hasPart         tern-shapes:IGSN-isPartOf;
        sdo:hasPart         <urn:shape:transectStartPoint-min-1>;
        sdo:hasPart         tern-shapes:System-systemType;
        sdo:hasPart         tern-shapes:Taxon-taxonomicStatus;
        sdo:hasPart         tern-shapes:Taxon-nomenclaturalStatus;
        sdo:hasPart         tern-shapes:time-hasBeginning;
        sdo:hasPart         tern-shapes:Taxon-kingdom;
        sdo:hasPart         tern-shapes:tern-maxAltitude;
