        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "unit type";
        sh:description    "The temporal unit which provides the precision of a date-time value or scale of a temporal extent." .

_:b265  rdf:first  time:unitDay;
        rdf:rest   _:b266 .

_:b266  rdf:first  time:unitHour;
        rdf:rest   _:b267 .

_:b267  rdf:first  time:unitMinute;
        rdf:rest   _:b268 .

_:b268  rdf:first  time:unitMonth;
        rdf:rest   _:b269 .

_:b269  rdf:first  time:unitSecond;
        rdf:rest   _:b270 .

_:b270  rdf:first  time:unitWeek;
        rdf:rest   _:b271 .

_:b271  rdf:first  time:unitYear;
        rdf:rest   rdf:nil .

tern-shapes:time-unitType
        sh:in        _:b265;
