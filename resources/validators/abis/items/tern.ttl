                            sh:path         dcterms:source
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "digital camera preferred label";
                            sh:description  "The preferred label for the digital camera.";
                            sh:message      "A `tern:DigitalCamera` _MUST_ have at least 1 `skos:prefLabel` predicate.";
                            sh:minCount     1;
                            sh:name         "skos:prefLabel";
                            sh:path         skos:prefLabel
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "digital camera model";
                            sh:description  "The model as defined by the manufacturer.";
                            sh:message      "A `tern:DigitalCamera` _MUST_ have at least 1 `schema:model` predicate.";
                            sh:minCount     1;
