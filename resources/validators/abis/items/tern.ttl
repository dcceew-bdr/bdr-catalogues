        sh:message   "A `time:Duration` _MUST_ have exactly 1 `time:unitType` predicate where the value node is an IRI from a controlled list.";
        sh:minCount  1;
        sh:name      "time:unitType";
        sh:nodeKind  sh:IRI;
        sh:path      time:unitType .

