        sh:property       tern-shapes:tern-isAttributeOf , tern-shapes:dcterms-type , tern-shapes:void-inDataset , tern-shapes:tern-hasSimpleValue , tern-shapes:tern-attribute , tern-shapes:tern-hasValue;
        sh:targetClass    tern:Attribute .

tern-shapes:Intervention
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
