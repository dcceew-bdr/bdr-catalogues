        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "exact match";
        sh:description    "Indicates that two concepts, terms, or resources are semantically equivalent and can be used interchangeably. Used to link a resource to its exact corresponding match in another system or vocabulary.";
        sh:message        "A resource _MAY_ have a `skos:exactMatch` predicate where the value is an IRI.";
        sh:name           "skos:exactMatch";
        sh:nodeKind       sh:IRI;
        sh:path           skos:exactMatch .

