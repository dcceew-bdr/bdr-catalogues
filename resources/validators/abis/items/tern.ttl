        sh:class          skos:Concept;
        sh:description    "The type of platform.";
        sh:maxCount       1;
        sh:message        "A `tern:Platform` _MUST_ have exactly 1 `tern:platformType` predicate where the value node is a skos:Concept.";
        sh:minCount       1;
        sh:name           "tern:platformType";
        sh:path           tern:platformType .

tern-shapes:RDFDataset-vocabulary
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "vocabulary";
        sh:description    "A vocabulary or `owl:Ontology` whose classes or properties are used in a `void:Dataset`.";
        sh:message        "A `tern:RDFDataset` _MAY_ have a `void:vocabulary` predicate where the value node is an IRI.";
        sh:name           "void:vocabulary";
        sh:nodeKind       sh:IRI;
        sh:path           void:vocabulary .

tern-shapes:tern-calibratesProperty
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "calibrates property";
        sh:class          ssn-system:SystemProperty;
        sh:description    "Relation from a calibration activity to a system property that is being calibrated. This property is used to specify which system property is the target of the calibration.";
        sh:message        "A `tern:calibratesProperty` predicate _MUST_ have an IRI or blank node value of type `ssn-system:SystemProperty`.";
        sh:name           "tern:calibratesProperty" .

