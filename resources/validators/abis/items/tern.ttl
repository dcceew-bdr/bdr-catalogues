        skos:prefLabel    "purpose";
        sh:datatype       xsd:string;
        sh:description    "Describe the purpose of something.";
        sh:message        "A `tern:purpose` predicate has a literal value with the datatype `xsd:string`.";
        sh:name           "tern:purpose";
        sh:path           tern:purpose .

