        sh:maxCount       1;
        sh:message        "A `tern:Observation` _MUST_ have exactly 1 `sosa:observedProperty` where the value node is an IRI.";
        sh:minCount       1;
        sh:name           "sosa:observedProperty";
        sh:nodeKind       sh:IRI;
        sh:path           sosa:observedProperty .

