        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "maximum inclusive value";
        sh:description    "The inclusive upper bound of the measurement range. This value represents the maximum value that can be measured by the sensor.";
        sh:maxCount       1;
        sh:message        "A `qudt:maxInclusive` predicate _MAY_ have maximum one literal value representing the upper bound of the measurement range.";
        sh:name           "qudt:maxInclusive";
        sh:nodeKind       sh:Literal;
