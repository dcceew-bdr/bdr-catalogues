tern-shapes:FluxTower
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Flux Tower";
        reg:status        reg:statusStable;
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower ozflux ID";
                            sh:datatype     xsd:string;
                            sh:description  "The OzFlux ID of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `tern:ozfluxID` predicate with a string value.";
                            sh:name         "tern:ozfluxID";
                            sh:path         tern:ozfluxID
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower description";
                            sh:datatype     xsd:string;
                            sh:description  "The description of the flux tower.";
                            sh:message      "If present, `dcterms:description` predicates on a `tern:FluxTower` _MUST_ have string values.";
                            sh:name         "dcterms:description";
                            sh:path         dcterms:description
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower IGBP code";
                            sh:datatype     xsd:string;
                            sh:description  "The IGBP code of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `tern:igbpCode` predicate with a string value.";
                            sh:name         "tern:igbpCode";
                            sh:path         tern:igbpCode
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "decommissioned date of flux tower";
                            sh:datatype     xsd:date;
                            sh:description  "The date when the flux tower was decommissioned.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `tern:dateDecommissioned` predicate with a date value.";
                            sh:name         "tern:dateDecommissioned";
                            sh:path         tern:dateDecommissioned
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower label";
                            sh:datatype     xsd:string;
                            sh:description  "The label of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MUST_ have exactly 1 `rdfs:label` predicate with a string value.";
                            sh:minCount     1;
                            sh:name         "rdfs:label";
                            sh:path         rdfs:label
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower purpose";
                            sh:datatype     xsd:string;
                            sh:description  "The purpose of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `tern:purpose` predicate with a string value.";
                            sh:name         "tern:purpose";
                            sh:path         tern:purpose
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower comment";
                            sh:datatype     xsd:string;
                            sh:description  "Comments about the flux tower.";
                            sh:message      "If present, `rdfs:comment` predicates on a `tern:FluxTower` _MUST_ have string values.";
                            sh:name         "rdfs:comment";
                            sh:path         rdfs:comment
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "flux tower centroid point";
                            sh:class        sf:Point;
                            sh:description  "The centroid point of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MUST_ have exactly 1 `tern:centroidPoint` predicate with a value of type `sf:Point`.";
                            sh:minCount     1;
                            sh:name         "tern:centroidPoint";
                            sh:path         tern:centroidPoint
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower fluxnet ID";
                            sh:datatype     xsd:string;
                            sh:description  "The FLUXNET ID of the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `tern:fluxnetID` predicate with a string value.";
                            sh:name         "tern:fluxnetID";
                            sh:path         tern:fluxnetID
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "commissioned date of flux tower";
                            sh:datatype     xsd:date;
                            sh:description  "The date when the flux tower was commissioned.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MUST_ have exactly 1 `tern:dateCommissioned` predicate with a date value.";
                            sh:minCount     1;
                            sh:name         "tern:dateCommissioned";
                            sh:path         tern:dateCommissioned
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "flux tower is hosted by";
                            sh:class        tern:Site;
                            sh:description  "The site that hosts the flux tower.";
                            sh:maxCount     1;
                            sh:message      "A `tern:FluxTower` _MAY_ have at most 1 `sosa:isHostedBy` predicate with a value of type `tern:Site`.";
                            sh:name         "sosa:isHostedBy";
                            sh:path         sosa:isHostedBy
                          ];
        sh:targetClass    tern:FluxTower .

