        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "local vocabulary of observable property";
                            sh:description  "The local vocabulary of the observable property.";
                            sh:maxCount     1;
                            sh:message      "A `tern:ObservableProperty` _MAY_ have at most 1 `tern:localVocabulary` predicate with a value of type `skos:ConceptScheme`, `skos:Collection`, or `owl:Ontology`.";
                            sh:name         "tern:localVocabulary";
                            sh:or           ( [ sh:class  skos:ConceptScheme ]
                                              [ sh:class  skos:Collection ]
                                              [ sh:class  owl:Ontology ]
                                            );
                            sh:path         tern:localVocabulary
                          ];
        sh:targetClass    tern:ObservableProperty .

