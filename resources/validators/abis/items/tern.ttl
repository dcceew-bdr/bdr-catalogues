class , tern-shapes:prov-startedAtTime , tern-shapes:tern-resourceSpecificUsage , tern-shapes:ObservationCollection-hasFeatureOfInterest , tern-shapes:sosa-hasFeatureOfInterest , tern-shapes:tern-minAltitude , tern-shapes:tern-calibratedBy , tern-shapes:Taxon-namePublishedInYear , tern-shapes:Taxon-originalNameUsageID , tern-shapes:Float-uncertainty , tern-shapes:Taxon-nameAccordingToID , tern-shapes:IGSN-publisher , tern-shapes:schema-model , tern-shapes:Sampling-madeBySampler , tern-shapes:prov-wasAttributedTo , tern-shapes:Site-hasSiteVisit , tern-shapes:DateTime-value , tern-shapes:Value-value , tern-shapes:schema-serialNumber , tern-shapes:sosa-hasSample , tern-shapes:dcterms-type , tern-shapes:FluxTower , tern-shapes:Taxon-taxonID , tern-shapes:tern-hasIGSN , tern-shapes:RDFDataset , tern-shapes:Text , tern-shapes:Taxon-genericName , tern-shapes:Taxon-phylum , tern-shapes:Taxon-taxonRemarks , tern-shapes:prov-wasAssociatedWith , tern-shapes:Date , tern-shapes:Taxon-nomenclaturalCode , tern-shapes:Sampler , tern-shapes:Association-agent , tern-shapes:Taxon-scientificName , tern-shapes:skos-scopeNote , tern-shapes:Taxon-genus , tern-shapes:tern-supplementalInformation , tern-shapes:tern-observationType , tern-shapes:ObservableProperty , tern-shapes:ObservationCollection-madeBySensor , tern-shapes:ssn-deployedSystem , tern-shapes:tern-environmentDescription , tern-shapes:System , tern-shapes:Sampling-hasResult , tern-shapes:sosa-isFeatureOfInterestOf , tern-shapes:Taxon-acceptedNameUsageID , tern-shapes:sosa-madeBySensor , tern-shapes:Taxon-subgenus , tern-shapes:Float , <urn:shape:sdo-spatial-min-1> , tern-shapes:tern-verifiesCapability , <urn:shape:Sample-isSampleOf-spatial> , tern-shapes:Transect , tern-shapes:tern-climateCode , tern-shapes:geo-sfWithin , tern-shapes:time-Instant-inDateTime , tern-shapes:dwc-materialSampleID , tern-shapes:tern-hasSite , tern-shapes:Value-unit , tern-shapes:Taxon-acceptedNameUsage , tern-shapes:Taxon-higherClassification , tern-shapes:RDFDataset-modified , tern-shapes:Procedure , tern-shapes:Taxon-namePublishedIn , tern-shapes:tern-unit , tern-shapes:Dataset , tern-shapes:skos-altLabel , tern-shapes:time-hasDuration , tern-shapes:prov-endedAtTime , tern-shapes:void-inDataset , tern-shapes:Instant , tern-shapes:sosa-usedProcedure , tern-shapes:IGSN-hasPart , tern-shapes:Value , tern-shapes:RDFDataset-title , tern-shapes:Transect-spatial , tern-shapes:ManagedFeature , tern-shapes:Taxon-subfamily , tern-shapes:Association-hadPlan , <urn:shape:Observation-hasFeatureOfInterest-Sample> , tern-shapes:Taxon-taxonRank , tern-shapes:Sensor-implements , tern-shapes:tern-dateDecommissioned , tern-shapes:Interval , tern-shapes:dcat-contactPoint , tern-shapes:ObservationCollection-hasUltimateFeatureOfInterest , tern-shapes:tern-undertakenComplementarily , tern-shapes:Taxon-infraspecificEpithet , tern-shapes:tern-editor , tern-shapes:tern-sampleSubType , tern-shapes:sosa-hasSimpleResult , tern-shapes:tern-hasSimpleValue , tern-shapes:ObservationCollection-hasMember , tern-shapes:RDFDataset-source , <urn:shape:Sample-isSampleOf-sfWithin> , tern-shapes:Deployment , tern-shapes:tern-calibrationActualResult , tern-shapes:Sample-isSampleOf , tern-shapes:Taxon-originalNameUsage , tern-shapes:Attribute , tern-shapes:Intervention , tern-shapes:RDFDataset-subset , tern-shapes:RDFDataset-created , tern-shapes:IGSN , tern-shapes:FeatureOfInterest-featureType , tern-shapes:Taxon-namePublishedInID , tern-shapes:dcterms-source , tern-shapes:Taxon-cultivarEpithet , tern-shapes:RDFDataset-publisher , tern-shapes:Observation , tern-shapes:Site-dimension , tern-shapes:Site , tern-shapes:Association-hadRole , tern-shapes:ObservationCollection-phenomenonTime , tern-shapes:RDFDataset-rightsHolder , tern-shapes:tern-dateCommissioned , tern-shapes:tern-undertakenAfter , tern-shapes:geo-hasGeometry , tern-shapes:VerticalExtent , tern-shapes:Transect-featureType , tern-shapes:tern-attribute , tern-shapes:DigitalCamera , tern-shapes:RDFDataset-license , tern-shapes:Integer , tern-shapes:Association , tern-shapes:Taxon-family , tern-shapes:System-hasDeployment , tern-shapes:Result , tern-shapes:ObservationCollection , tern-shapes:tern-hasValue , tern-shapes:Taxon , tern-shapes:tern-hasAttribute , tern-shapes:Survey , tern-shapes:DateTime , tern-shapes:RDFDataset-issued , tern-shapes:Taxon-infragenericEpithet , tern-shapes:IGSN-hasGeometry , tern-shapes:ObservationCollection-usedProcedure , tern-shapes:Transect-hasGeometry , tern-shapes:Taxon-scientificNameID , tern-shapes:Taxon-order , tern-shapes:Sensor-observes , tern-shapes:prov-qualifiedAttribution , tern-shapes:Taxon-parentNameUsageID , tern-shapes:Integer-value , <urn:shape:geo-sfWithin-min-1> , tern-shapes:MeasurementRange , tern-shapes:Sensor , tern-shapes:SiteVisit , tern-shapes:qudt-maxInclusive , tern-shapes:tern-undertakenConcurrently , tern-shapes:skos-exactMatch , tern-shapes:time-unitType , tern-shapes:RDFDataset-contributor , tern-shapes:Site-locationProcedure , tern-shapes:Sample-isResultOf , tern-shapes:tern-platformType , tern-shapes:RDFDataset-vocabulary , tern-shapes:tern-calibratesProperty , tern-shapes:tern-hasCalibration , <urn:shape:transectEndPoint-min-1> , tern-shapes:Taxon-vernacularName , tern-shapes:tern-interventionType , tern-shapes:RDFDataset-date , <urn:shape:Activity> , tern-shapes:skos-prefLabel , tern-shapes:time-numericDuration , tern-shapes:Attribution-agent , tern-shapes:IRI-value , tern-shapes:tern-wasInformedBy , tern-shapes:Sensor-madeObservation , tern-shapes:Result-isResultOf , tern-shapes:dcterms-identifier , tern-shapes:ssn-system-hasOperatingProperty , tern-shapes:sosa-madeSampling , <urn:shape:Sampling-hasResult-Site-sdo-spatial> , tern-shapes:sdo-spatial , tern-shapes:Method , tern-shapes:Boolean-value , tern-shapes:Input , tern-shapes:rdfs-comment , tern-shapes:qudt-maxExclusive , tern-shapes:tern-siteDescription , tern-shapes:dcterms-description , tern-shapes:tern-locationDescription , tern-shapes:Dimension , tern-shapes:Text-value , tern-shapes:Sample , tern-shapes:ssn-system-hasSystemCapability , tern-shapes:Calibration , tern-shapes:FeatureOfInterest , tern-shapes:prov-qualifiedAssociation , tern-shapes:Transect-transectEndPoint , tern-shapes:qudt-minInclusive .

tern-shapes:Sample-isResultOf
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "is result of";
        sh:class          tern:Sampling;
        sh:description    "Relation linking a Result to the Sampling that created or caused it.";
        sh:message        "A `tern:Sample` _MAY_ have a `sosa:isResultOf` predicate where the value node is an IRI of type `tern:Sampling`.";
        sh:name           "sosa:isResultOf";
        sh:nodeKind       sh:IRI;
        sh:path           sosa:isResultOf .

tern-shapes:tern-platformType
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "platform type";
        sh:class          skos:Concept;
        sh:description    "The type of platform.";
        sh:maxCount       1;
        sh:message        "A `tern:Platform` _MUST_ have exactly 1 `tern:platformType` predicate where the value node is a skos:Concept.";
        sh:minCount       1;
        sh:name           "tern:platformType";
        sh:path           tern:platformType .

tern-shapes:RDFDataset-vocabulary
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "vocabulary";
        sh:description    "A vocabulary or `owl:Ontology` whose classes or properties are used in a `void:Dataset`.";
        sh:message        "A `tern:RDFDataset` _MAY_ have a `void:vocabulary` predicate where the value node is an IRI.";
        sh:name           "void:vocabulary";
        sh:nodeKind       sh:IRI;
        sh:path           void:vocabulary .

tern-shapes:tern-calibratesProperty
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "calibrates property";
        sh:class          ssn-system:SystemProperty;
        sh:description    "Relation from a calibration activity to a system property that is being calibrated. This property is used to specify which system property is the target of the calibration.";
        sh:message        "A `tern:calibratesProperty` predicate _MUST_ have an IRI or blank node value of type `ssn-system:SystemProperty`.";
        sh:name           "tern:calibratesProperty";
        sh:nodeKind       [ sh:in   ( sh:IRI sh:BlankNode )
                          ];
        sh:path           tern:calibratesProperty .

tern-shapes:tern-hasCalibration
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "has calibration";
        sh:class          tern:Calibration;
        sh:description    "Relation between a System and a Calibration, recording that the System is calibrated.";
        sh:message        "A `tern:System` _MAY_ have an `tern:hasCalibration` predicate where the value node is an IRI of type `tern:Calibration`.";
        sh:name           "tern:hasCalibration";
        sh:path           tern:hasCalibration .

<urn:shape:transectEndPoint-min-1>
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "transect end point min 1";
        sh:description    "At least one tern:transectEndPoint must exist.";
        sh:message        "At least one tern:transectEndPoint must exist.";
        sh:minCount       1;
        sh:name           "tern:transectEndPoint";
        sh:path           tern:transectEndPoint .

tern-shapes:Taxon-vernacularName
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "vernacular name";
        sh:datatype       xsd:string;
        sh:description    "A common or vernacular name.";
        sh:message        "A `tern:Taxon` _MAY_ have a `dwc:vernacularName` predicate where the value node is a literal with the datatype `xsd:string`.";
        sh:name           "dwc:vernacularName";
        sh:nodeKind       sh:Literal;
        sh:path           dwc:vernacularName .

tern-shapes:tern-interventionType
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "intervention type";
        sh:description    "The type of intervention.";
        sh:maxCount       1;
        sh:message        "A `tern:Intervention` _MAY_ have a maximum of 1 `tern:interventionType` predicate where the value node is an IRI.";
        sh:name           "tern:interventionType";
        sh:nodeKind       sh:IRI;
        sh:path           tern:interventionType .

tern-shapes:RDFDataset-date
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "date";
        sh:datatype       xsd:date;
        sh:description    "A point or period of time associated with an event in the life-cycle of the resource. The value should be formatted and data-typed as an `xsd:date`.";
        sh:message        "A `tern:RDFDataset` _MAY_ have a `dcterms:date` predicate where the value node is a literal with the datatype `xsd:date`.";
        sh:name           "dcterms:date";
        sh:path           dcterms:date .

<urn:shape:Activity>  rdf:type  sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Activity spatial shape";
        sh:message        "At least one (geo:hasGeoemtry, geo:sfWithin) must exist on itself or on a sample in the chain of samples)";
        sh:or             ( <urn:shape:geo-hasGeometry-min-1> <urn:shape:sdo-spatial-min-1> <urn:shape:geo-sfWithin-min-1> <urn:shape:Observation-hasFeatureOfInterest> <urn:shape:Sampling-hasResult-Site-sdo-spatial> );
        sh:targetClass    tern:Observation , tern:Sampling .

tern-shapes:skos-prefLabel
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "preferred label";
        sh:description    "The preferred label of the resource.";
        sh:message        "A `skos:prefLabel` predicate _MUST_ have a literal value.";
        sh:name           "skos:prefLabel";
        sh:nodeKind       sh:Literal;
        sh:path           skos:prefLabel .

tern-shapes:time-numericDuration
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "numeric duration";
        sh:datatype       xsd:decimal;
        sh:description    "Value of a temporal extent expressed as a decimal number scaled by a temporal unit";
        sh:maxCount       1;
        sh:message        "A `time:Duration` _MUST_ have exactly 1 `time:numericDuration` predicate where the value node is a literal with a datatype of `xsd:decimal`.";
        sh:minCount       1;
        sh:name           "time:numericDuration";
        sh:path           time:numericDuration .

tern-shapes:Attribution-agent
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "agent";
        sh:class          prov:Agent;
        sh:description    "An agent is something that bears some form of responsibility for an activity taking place, for the existence of an entity, or for another agent's activity.";
        sh:maxCount       1;
        sh:message        "A `prov:Attribution` _MUST_ have exactly 1 `prov:agent` predicate where the value node is an IRI of an individual with the type `prov:Agent`.";
        sh:minCount       1;
        sh:name           "prov:agent";
        sh:nodeKind       sh:IRI;
        sh:path           prov:agent .

tern-shapes:IRI-value
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "value";
        sh:description    "An IRI value.";
        sh:maxCount       1;
        sh:message        "A `tern:IRI` _MUST_ have exactly 1 `rdf:value` predicate where the value node is an IRI.";
        sh:minCount       1;
        sh:name           "rdf:value";
        sh:nodeKind       sh:IRI;
        sh:path           rdf:value .

tern-shapes:tern-wasInformedBy
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "was informed by";
        sh:description    "Communication is the exchange of an entity by two activities, one activity using the entity generated by the other.";
        sh:message        "A `prov:wasInformedBy` predicate _MUST_ have an IRI value.";
        sh:name           "prov:wasInformedBy";
        sh:nodeKind       sh:IRI;
        sh:path           prov:wasInformedBy .

tern-shapes:Sensor-madeObservation
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "made observation";
        sh:class          tern:Observation;
        sh:description    "Relation between a `Sensor` and an `Observation` made by the `Sensor`.";
        sh:message        "A `tern:Sensor` _MAY_ have an `sosa:madeObservation` predicate where the value node is an IRI of type `tern:Observation`.";
        sh:name           "sosa:madeObservation";
        sh:nodeKind       sh:IRI;
        sh:path           sosa:madeObservation .

tern-shapes:Result-isResultOf
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "is result of";
        sh:description    "Relation linking a Result to the Observation or Actuation or act of Sampling that created or caused it.";
        sh:maxCount       1;
        sh:message        "A `tern:Result` _MAY_ have at most 1 `sosa:isResultOf` predicate where the value node is an IRI of type `tern:Observation` or `tern:Sampling`.";
        sh:name           "sosa:isResultOf";
        sh:or             ( [ sh:class  tern:Observation ]
                            [ sh:class  tern:Sampling ]
                          );
        sh:path           sosa:isResultOf .

tern-shapes:dcterms-identifier
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "identifier";
        sh:description    "An unambiguous reference to the resource within a given context.";
        sh:message        "N/A";
        sh:name           "dcterms:identifier";
        sh:path           dcterms:identifier .

tern-shapes:ssn-system-hasOperatingProperty
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "has operating property";
        sh:class          ssn-system:OperatingProperty;
        sh:description    "Relation from an OperatingRange of a System to an OperatingProperty describing the operating range of the System. This property is used to specify the operating characteristics or properties that define the operating conditions of a system.";
        sh:message        "A `ssn-system:hasOperatingProperty` predicate _MUST_ have an IRI or blank node value of type `ssn-system:OperatingProperty`.";
        sh:name           "ssn-system:hasOperatingProperty";
        sh:nodeKind       [ sh:in   ( sh:IRI sh:BlankNode )
                          ];
        sh:path           ssn-system:hasOperatingProperty .

tern-shapes:sosa-madeSampling
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "made sampling";
        sh:class          tern:Sampling;
        sh:description    "Relation between a Sampler (sampling device or entity) and the Sampling act it performed.";
        sh:message        "A `sosa:madeSampling` predicate _MAY_ exist where the value node is an IRI.";
        sh:name           "sosa:madeSampling";
        sh:nodeKind       sh:IRI;
        sh:path           sosa:madeSampling .

<urn:shape:Sampling-hasResult-Site-sdo-spatial>
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Sampling has result Site with spatial";
        sh:property       [ sh:path                 sosa:hasResult;
                            sh:qualifiedMinCount    1;
                            sh:qualifiedValueShape  [ sh:class     tern:Site;
                                                      sh:property  [ sh:minCount  1;
                                                                     sh:path      sdo:spatial
                                                                   ]
                                                    ]
                          ] .

tern-shapes:sdo-spatial
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "spatial";
        sh:class          geo:Geometry;
        sh:description    "A spatial representation for a given feature.";
        sh:message        "A `sdo:spatial` predicate _MUST_ have a blank node or IRI value.";
        sh:name           "sdo:spatial";
        sh:nodeKind       sh:BlankNodeOrIRI;
        sh:path           sdo:spatial .

tern-shapes:time-inXSDgYearMonth
        reg:status      reg:statusStable;
        skos:prefLabel  "in XSD g-year-month";
        sh:datatype     xsd:gYearMonth;
        sh:description  "Position of an instant, expressed using `xsd:gYearMonth`.";
        sh:maxCount     1;
        sh:message      "Value _MUST_ be a literal with a datatype of `xsd:gYearMonth`. Maximum of one value is allowed for this property.";
        sh:name         "time:inXSDgYearMonth";
        sh:nodeKind     sh:Literal;
        sh:path         time:inXSDgYearMonth .

tern-shapes:Method  rdf:type  sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Method";
        reg:status        reg:statusStable;
        sh:property       tern-shapes:tern-undertakenBefore , tern-shapes:tern-undertakenComplementarily , tern-shapes:tern-undertakenAfter , tern-shapes:tern-undertakenConcurrently;
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "categorial collection of method";
                            sh:class        skos:Collection;
                            sh:description  "The categorical collection of the method.";
                            sh:message      "If present, `tern:hasCategoricalCollection` predicates on a `tern:Method` _MUST_ have values of type `skos:Collection`.";
                            sh:name         "tern:hasCategoricalCollection";
                            sh:path         tern:hasCategoricalCollection
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "note of method";
                            sh:datatype     xsd:string;
                            sh:description  "Notes about the method.";
                            sh:message      "If present, `skos:note` predicates on a `tern:Method` _MUST_ have string values.";
                            sh:name         "skos:note";
                            sh:path         skos:note
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "parameter of method";
                            sh:class        skos:Concept;
                            sh:description  "The parameters of the method.";
                            sh:message      "If present, `tern:hasParameter` predicates on a `tern:Method` _MUST_ have values of type `skos:Concept`.";
                            sh:name         "tern:hasParameter";
                            sh:path         tern:hasParameter
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method scope";
                            sh:datatype     xsd:string;
                            sh:description  "The scope of the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `tern:scope` predicate with a string value.";
                            sh:name         "tern:scope";
                            sh:path         tern:scope
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method purpose";
                            sh:datatype     xsd:string;
                            sh:description  "The purpose of the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `tern:purpose` predicate with a string value.";
                            sh:name         "tern:purpose";
                            sh:path         tern:purpose
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method definition";
                            sh:datatype     xsd:string;
                            sh:description  "The definition of the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `skos:definition` predicate with a string value.";
                            sh:name         "skos:definition";
                            sh:path         skos:definition
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "method required duration";
                            sh:datatype     xsd:string;
                            sh:description  "The time required for the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `schema:timeRequired` predicate with a string value.";
                            sh:name         "schema:timeRequired";
                            sh:path         <http://schema.org/timeRequired>
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method instructions";
                            sh:class        rdf:Seq;
                            sh:description  "The instructions for the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `tern:instructions` predicate with a value of type `rdf:Seq`.";
                            sh:name         "tern:instructions";
                            sh:path         tern:instructions
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method equipment";
                            sh:class        skos:Concept;
                            sh:description  "The equipment used for the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MAY_ have at most 1 `tern:equipment` predicate with a value of type `skos:Concept`.";
                            sh:name         "tern:equipment";
                            sh:path         tern:equipment
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "digital camera preferred label";
                            sh:description  "The source of the method.";
                            sh:message      "If present, `dcterms:source` predicates on a `tern:Method` _MUST_ have string or URI values.";
                            sh:name         "dcterms:source";
                            sh:or           ( [ sh:datatype  xsd:string ]
                                              [ sh:datatype  xsd:anyURI ]
                                            );
                            sh:path         dcterms:source
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusStable;
                            skos:prefLabel  "method preferred label";
                            sh:datatype     xsd:string;
                            sh:description  "The preferred label of the method.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Method` _MUST_ have exactly 1 `skos:prefLabel` predicate with a string value.";
                            sh:minCount     1;
                            sh:name         "skos:prefLabel";
                            sh:path         skos:prefLabel
                          ];
        sh:targetClass    tern:Method .

tern-shapes:Boolean-value
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "value";
        sh:datatype       xsd:boolean;
        sh:description    "The boolean value.";
        sh:in             ( true false );
        sh:maxCount       1;
        sh:message        "`tern:Boolean` _MUST_ have exactly 1 `rdf:value` predicate where the value node is a literal with a datatype of `xsd:boolean`.";
        sh:minCount       1;
        sh:name           "rdf:value";
        sh:path           rdf:value .

tern-shapes:Input  rdf:type  sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Input";
        reg:status        reg:statusStable;
        sh:property       tern-shapes:void-inDataset , tern-shapes:tern-hasAttribute;
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "input description";
                            sh:datatype     xsd:string;
                            sh:description  "The description of the input.";
                            sh:message      "If present, `dcterms:description` predicates on a `tern:Input` _MUST_ have string values.";
                            sh:name         "dcterms:description";
                            sh:path         dcterms:description
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "input value";
                            sh:description  "The value of the input.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Input` _MAY_ have at most 1 `rdf:value` predicate.";
                            sh:name         "rdf:value";
                            sh:path         rdf:value
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "input label";
                            sh:datatype     xsd:string;
                            sh:description  "The label of the input.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Input` _MUST_ have exactly 1 `rdfs:label` predicate with a string value.";
                            sh:minCount     1;
                            sh:name         "rdfs:label";
                            sh:path         rdfs:label
                          ];
        sh:targetClass    tern:Input .

tern-shapes:rdfs-comment
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "comment";
        sh:description    "A description of the subject resource.";
        sh:message        "An `rdfs:comment` _MUST_ have a literal value.";
        sh:name           "rdfs:comment";
        sh:nodeKind       sh:Literal;
        sh:path           rdfs:comment .

tern-shapes:qudt-maxExclusive
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "maximum exclusive value";
        sh:description    "The exclusive upper bound of the measurement range. This value represents the value just above the maximum that can be measured by the sensor.";
        sh:maxCount       1;
        sh:message        "A `qudt:maxExclusive` predicate _MAY_ have maximum one literal value representing the exclusive upper bound of the measurement range.";
        sh:name           "qudt:maxExclusive";
        sh:nodeKind       sh:Literal;
        sh:path           qudt:maxExclusive .

tern-shapes:tern-siteDescription
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "site description";
        sh:datatype       xsd:string;
        sh:description    "The description of the site.\n\nExample: Outer fringe of larger lake chain, isolated by reddish dunes, yellow sand fan into western edge. Very few, 3, plants regenerating after recent moderate rains. Silt, sand with scattered iron conglomerate stones on surface.";
        sh:maxCount       1;
        sh:message        "A `tern:siteDescription` _MUST_ have a literal value with the datatype `xsd:string`.";
        sh:name           "tern:siteDescription";
        sh:nodeKind       sh:Literal;
        sh:path           tern:siteDescription .

tern-shapes:dcterms-description
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "description";
        sh:datatype       xsd:string;
        sh:description    "A textual description.";
        sh:message        "A `dcterms:description` predicate has a literal value with the datatype `xsd:string`.";
        sh:name           "dcterms:description";
        sh:path           dcterms:description .

tern-shapes:tern-locationDescription
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "location description";
        sh:datatype       xsd:string;
        sh:description    "The description of the site's location. Example: 10km west of Fletcherview Tropical Rangeland SuperSite.";
        sh:maxCount       1;
        sh:message        "A `tern:locationDescription` _MUST_ have a literal value with the datatype `xsd:string`.";
        sh:name           "tern:locationDescription";
        sh:nodeKind       sh:Literal;
        sh:path           tern:locationDescription .

tern-shapes:Dimension
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Dimension";
        reg:status        reg:statusStable;
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "dimension length";
                            sh:description  "The length dimension.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Dimension` _MUST_ have exactly 1 `tern:length` predicate with a double or integer value.";
                            sh:minCount     1;
                            sh:name         "tern:length";
                            sh:or           ( [ sh:datatype  xsd:double ]
                                              [ sh:datatype  xsd:integer ]
                                            );
                            sh:path         tern:length
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "diemnsion width";
                            sh:description  "The width dimension.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Dimension` _MUST_ have exactly 1 `tern:width` predicate with a double or integer value.";
                            sh:minCount     1;
                            sh:name         "tern:width";
                            sh:or           ( [ sh:datatype  xsd:double ]
                                              [ sh:datatype  xsd:integer ]
                                            );
                            sh:path         tern:width
                          ];
        sh:property       [ rdf:type        sh:PropertyShape;
                            reg:status      reg:statusExperimental;
                            skos:prefLabel  "dimension unit";
                            sh:class        qudt:Unit;
                            sh:description  "The unit of measurement for the dimensions.";
                            sh:maxCount     1;
                            sh:message      "A `tern:Dimension` _MUST_ have exactly 1 `tern:unit` predicate with a value of type `qudt:Unit`.";
                            sh:minCount     1;
                            sh:name         "tern:unit";
                            sh:path         tern:unit
                          ];
        sh:targetClass    tern:Dimension .

tern-shapes:Text-value
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "value";
        sh:description    "The text value.";
        sh:maxCount       1;
        sh:message        "A `tern:Text` _MUST_ have exactly 1 `rdf:value` predicate where the value node is a literal with the datatype `xsd:string` or `rdf:langString`.";
        sh:minCount       1;
        sh:name           "rdf:value";
        sh:or             ( [ sh:datatype  xsd:string ]
                            [ sh:datatype  rdf:langString ]
                          );
        sh:path           rdf:value .

tern-shapes:Sample  rdf:type  sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Sample";
        sh:property       tern-shapes:tern-hasIGSN , tern-shapes:Sample-isSampleOf , tern-shapes:tern-hasAttribute , tern-shapes:Sample-isResultOf;
        sh:targetClass    tern:Sample .

tern-shapes:ssn-system-hasSystemCapability
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "has system capability";
        sh:class          ssn-system:SystemCapability;
        sh:description    "Relation from a System to a SystemCapability describing the capabilities of the System under certain Conditions. This property is used to specify what a system is capable of doing under specific circumstances.";
        sh:message        "A `ssn-system:hasSystemCapability` predicate _MUST_ have an IRI or blank node value of type `ssn-system:SystemCapability`.";
        sh:name           "ssn-system:hasSystemCapability";
        sh:nodeKind       [ sh:in   ( sh:IRI sh:BlankNode )
                          ];
        sh:path           ssn-system:hasSystemCapability .

tern-shapes:Calibration
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Calibration";
        sh:property       tern-shapes:tern-calibrationOffset , tern-shapes:tern-calibrationReferenceResult , tern-shapes:prov-startedAtTime , tern-shapes:tern-calibratedBy , tern-shapes:tern-verifiesCapability , tern-shapes:prov-endedAtTime , tern-shapes:sosa-usedProcedure , tern-shapes:tern-calibrationActualResult , tern-shapes:tern-calibratesProperty , tern-shapes:dcterms-description;
        sh:targetClass    tern:Calibration .

tern-shapes:FeatureOfInterest
        rdf:type          sh:NodeShape;
        rdfs:isDefinedBy  tern-shapes:;
        rdfs:label        "Feature of Interest";
        sh:property       tern-shapes:prov-wasAttributedTo , tern-shapes:sosa-hasSample , tern-shapes:dcterms-type , tern-shapes:sosa-isFeatureOfInterestOf , tern-shapes:tern-hasSite , tern-shapes:void-inDataset , tern-shapes:FeatureOfInterest-featureType , tern-shapes:geo-hasGeometry , tern-shapes:tern-hasAttribute , tern-shapes:prov-qualifiedAttribution , tern-shapes:dcterms-identifier , tern-shapes:sdo-spatial , tern-shapes:rdfs-comment;
        sh:targetClass    tern:FeatureOfInterest .

tern-shapes:prov-qualifiedAssociation
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "qualified association";
        sh:class          prov:Association;
        sh:description    "An activity association is an assignment of responsibility to an agent for an activity, indicating that the agent had a role in the activity. It further allows for a plan to be specified, which is the plan intended by the agent to achieve some goals in the context of this activity.";
        sh:message        "A `prov:qualifiedAssociation` _MUST_ have a blank node or IRI value of type `prov:Association`.";
        sh:name           "prov:qualifiedAssociation";
        sh:nodeKind       sh:BlankNodeOrIRI;
        sh:path           prov:qualifiedAssociation .

tern-shapes:Transect-transectEndPoint
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusStable;
        skos:prefLabel    "transect end point";
        sh:description    "Relationship to the link:http://www.opengis.net/ont/sf#Point[sf:Point] or geo:Geometry representing the end of a transect.";
        sh:maxCount       1;
        sh:message        "A `tern:Transect` _MAY_ have a maximum of 1 `tern:transectEndPoint` predicate where the value node is an IRI of type `sf:Point` or `geo:Geometry`.";
        sh:name           "tern:transectEndPoint";
        sh:or             ( [ sh:class  sf:Point ]
                            [ sh:class  geo:Geometry ]
                          );
        sh:path           tern:transectEndPoint .

tern-shapes:qudt-minInclusive
        rdf:type          sh:PropertyShape;
        rdfs:isDefinedBy  tern-shapes:;
        reg:status        reg:statusExperimental;
        skos:prefLabel    "minimum inclusive value";
        sh:description    "The inclusive lower bound of the measurement range. This value represents the minimum value that can be measured by the sensor.";
        sh:maxCount       1;
        sh:message        "A `qudt:minInclusive` predicate _MAY_ have maximum one literal value representing the lower bound of the measurement range.";
        sh:name           "qudt:minInclusive";
        sh:nodeKind       sh:Literal;
        sh:path           qudt:minInclusive .
