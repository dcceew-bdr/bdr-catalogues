PREFIX sdo: <https://schema.org/>
PREFIX tern-shapes: <https://w3id.org/tern/shapes/tern/>

tern-shapes:Association-agent
        sdo:description  "An agent is something that bears some form of responsibility" .

tern-shapes:Association-hadPlan
        sdo:description  "A plan is an entity that represents a set of actions or steps" .

tern-shapes:Association-hadRole
        sdo:description  "prov:hadRole references the Role (i.e. the function of an entity with respect to an activity), in the context of an instantaneous usage, generation, association, start, and end." .

tern-shapes:Attribution-agent
        sdo:description  "A prov:Attribution must have a prov:agent predicate" .

tern-shapes:Attribution-hadRole
        sdo:description  "prov:hadRole references the Role (i.e. the function of an entity with respect to an activity), in the context of an instantaneous usage, generation, association, start, and end." .

tern-shapes:Boolean-value
        sdo:description  "tern:Boolean must have 1 rdf:value predicate" .

tern-shapes:Date-value
        sdo:description  "The value of the date object." .

tern-shapes:DateTime-value
        sdo:description  "The value of the datetime object." .

tern-shapes:FeatureOfInterest-featureType
        sdo:description  "The feature type of a tern:FeatureOfInterest from a controlled vocabulary." .

tern-shapes:Float-uncertainty
        sdo:description  "Measurement uncertainty expressed as a positive or negative value." .

tern-shapes:Float-value
        sdo:description  "Float value." .

tern-shapes:IGSN-hasGeometry
        sdo:description  "Relationship from tern:IGSN to a geo:Geometry using the geo:hasGeometry property." .

tern-shapes:IGSN-hasPart
        sdo:description  "Relationship from tern:IGSN to a tern:IGSN using the dcterms:hasPart property." .

tern-shapes:IGSN-isPartOf
        sdo:description  "Relationship from tern:IGSN to a tern:IGSN using the dcterms:isPartOf property." .

tern-shapes:IGSN-publisher
