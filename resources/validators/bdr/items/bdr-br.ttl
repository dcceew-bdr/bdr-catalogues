PREFIX : <https://linked.data.gov.au/def/abis/bdr-profile/validator/>
PREFIX drv: <https://linked.data.gov.au/def/bdr-pr/dr/validator/>
PREFIX abisv: <https://linked.data.gov.au/def/abis/validator/>
PREFIX dr: <https://linked.data.gov.au/def/bdr-pr/dr/>
PREFIX ds: <https://linked.data.gov.au/def/abis/bdr-profile/validator>
PREFIX ont: <https://linked.data.gov.au/def/abis/validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prof: <http://www.w3.org/ns/dx/prof/>
PREFIX profrole: <http://www.w3.org/ns/dx/prof/role/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX tern: <https://w3id.org/tern/ontologies/tern/>
PREFIX time: <http://www.w3.org/2006/time#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ds:
    a owl:Ontology ;
    owl:versionIRI :1.2 ;
    owl:versionInfo """1.2 2025-07: Tidy up for inclusion in the BDR Validators Catalogue

1.1 2025-05: Minor updates

1.0 2025-04: First version""" ;
    skos:historyNote "Created by the BDR Team in 2025 to validate data bound for the Biodiversity Data Repository" ;
    schema:copyrightNotice "(c) 2025 DCCEEW" ;
    schema:creator <https://linked.data.gov.au/org/bdr-team> ;
    schema:dateCreated "2022-05-11"^^xsd:date ;
    schema:dateModified "2026-04-07"^^xsd:date ;
    owl:imports
        <https://linked.data.gov.au/def/abis/validator> ,
        <https://linked.data.gov.au/def/bdr-pr/dr/validator> ,
        <https://linked.data.gov.au/def/bdr-pr/proj/validator> ,
        <http://www.opengis.net/def/geosparql/validator> ,
        <https://linked.data.gov.au/def/sosa-validator> ,
        <https://w3id.org/tern/shapes/tern/> ,
        <https://linked.data.gov.au/def/vocpub/validator> ;
    prof:hasResource 
    [
        prof:hasRole profrole:validation ;
        prof:hasArtifact <http://www.opengis.net/def/geosparql/validator> ;
        schema:name "GeoSPARQL" ;
        schema:url "file://geo.ttl" ;
    ] ,
    [
        prof:hasRole profrole:validation ;
        prof:hasArtifact <https://linked.data.gov.au/def/sosa-validator> ;
        schema:name "SOSA Validator" ;
        schema:url "file://sosa.ttl" ;
    ] ,
    [
        prof:hasRole profrole:validation ;
        prof:hasArtifact <https://w3id.org/tern/shapes/tern/> ;
        schema:name "TERN Ontology Shapes" ;
        schema:url "file://tern.ttl" ;
    ] ,
    [
        prof:hasRole profrole:validation ;
        prof:hasArtifact <https://linked.data.gov.au/def/vocpub/validator> ;
        schema:name "VocPub Validator" ;
        schema:url "file://vocpub.ttl" ;
    ] ;
    schema:description "SHACL validator for the Biodiversity Data Repository (BDR)'s profile of Australian Biodiversity Information Standard (ABIS)" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:copyrightHolder <https://linked.data.gov.au/org/dcceew> ;
    schema:name "BDR Profile of ABIS Core Validator" ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    schema:codeRepository "https://github.com/dcceew-bdr/bdr-catalogues/"^^xsd:anyURI ;
    schema:hasPart
        :shape-01 ,
        :shape-02 ,
        :shape-03 ,
        :shape-04 ,
        :shape-05 ,
        :shape-06 ,
        :shape-07 ,
        drv:shape-01 ,
        drv:shape-02 ,
        drv:shape-03 ,
        drv:shape-04 ,
        abisv:shape-01 ;
.

:1.2
    schema:name "1.2" ;
.

drv:shape-01
    a sh:NodeShape ;
    sh:property
        [
            sh:message "A Dataset that uses an embargoed until predicate must use it to indicate a xsd:date, xsd:dateTime or xsd:dateTimeStamp literal value" ;
            sh:or (

                [
                    sh:datatype xsd:date ;
                ]

                [
                    sh:datatype xsd:dateTime ;
                ]

                [
                    sh:datatype xsd:dateTimeStamp ;
                ]
            ) ;
            sh:path dr:embargoedUntil ;
        ] ,
        [
            sh:class schema:Project ;
            sh:message "If a Project is indicated as being part of something, the other thing must also be a Project" ;
            sh:path schema:isPartOf ;
        ] ;
    sh:targetClass
        schema:Project ,
        tern:Dataset ;
rdfs:isDefinedBy dr: ;
schema:name "Dataset embargoed date values and Project has part Project" ; 
schema:description "Datasets using embargoedUntil date values and Project hasPart Project" ; 
.

drv:shape-02
    a sh:NodeShape ;
    sh:property
        [
            sh:class time:DurationDescription ;
            sh:message "A Dataset that uses an embargo period predicate MUST use it to indicate an instance of the class time:DurationDescription from OWL Time" ;
            sh:path dr:embargoPeriod ;
        ] ,
        [
            sh:class schema:Project ;
            sh:message "If a Project is indicated as having a part, the other thing MUST also be a Project" ;
            sh:path schema:hasPart ;
        ] ;
    sh:targetClass
        schema:Project ,
        tern:Dataset ;
    rdfs:isDefinedBy dr: ;
    schema:name "Dataset embargoe indicates OWL Time and Project has part Project" ; 
    schema:description "Dataset embargoe period indicates DurationDescription from OWL Time and Project hasPart Project" ; 
.

drv:shape-03
    a sh:NodeShape ;
    sh:property
        [
            sh:class tern:Dataset ;
            sh:message "If a Project is indicated as having generated something, that thing MUST be a tern:Dataset" ;
            sh:path prov:generated ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:message "If a Project indicates a qualified association, the indicated object MUST further indicate an Agent (Person or Organisation) with the prov:agent predicate" ;
            sh:minCount 1 ;
            sh:or (

                [
                    sh:class schema:Person ;
                ]

                [
                    sh:class schema:Organization ;
                ]
            ) ;
            sh:path prov:agent ;
        ] ;
    sh:targetClass schema:Project ;
    sh:targetObjectsOf prov:qualifiedAssociation ;
    rdfs:isDefinedBy dr: ;
    schema:name "Project generates Dataset and Project indicates associated Agent" ;
    schema:description "Project-generated datasets with qualified association indicating Agent with prov:Agent" ; 
.

drv:shape-04
    a sh:NodeShape ;
    sh:property
        [
            sh:maxCount 1 ;
            sh:message "If a Project indicates a qualified association, the indicated object must further indicate a Role for that association with the prov:role predicate" ;
            sh:minCount 1 ;
            sh:path prov:role ;
        ] ;
    sh:targetObjectsOf prov:qualifiedAssociation ;
    rdfs:isDefinedBy dr: ;
    schema:name "Project indicates association with Role" ;
    schema:description "Project indicating qualified association indicates role with prov:Agent" ; 
.

:shape-01
    a sh:NodeShape ;
    sh:message "Dataset IRIs must match the BDR Profile of ABIS' proscribed pattern of https://linked.data.gov.au/dataset/bdr/{UUID}" ;
    sh:pattern "^https://linked\\.data\\.gov\\.au/dataset/bdr/[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}$" ;
    sh:targetClass tern:Dataset ;
    schema:name "Dataset IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-02
    a sh:NodeShape ;
    sh:message "Site IRIs must match the BDR Profile of ABIS' proscribed pattern which includes linked.data.gov.au" ;
    sh:pattern "linked\\.data\\.gov\\.au" ;
    sh:targetClass tern:Site ;
    schema:name "Site IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-03
    a sh:NodeShape ;
    sh:message "Survey IRIs must match the BDR Profile of ABIS' proscribed pattern which includes linked.data.gov.au" ;
    sh:pattern "linked\\.data\\.gov\\.au" ;
    sh:targetClass tern:Survey ;
    schema:name "Survey IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-04
    a sh:NodeShape ;
    sh:message "SiteVisit IRIs must match the BDR Profile of ABIS' proscribed pattern which includes linked.data.gov.au" ;
    sh:pattern "linked\\.data\\.gov\\.au" ;
    sh:targetClass tern:SiteVisit ;
    schema:name "Site Visit IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-05
    a sh:NodeShape ;
    sh:message "Sample IRIs must match the BDR Profile of ABIS' proscribed pattern which includes linked.data.gov.au" ;
    sh:pattern "linked\\.data\\.gov\\.au" ;
    sh:targetClass tern:Sample ;
    schema:name "Sample IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-06
    a sh:NodeShape ;
    sh:message "Observation IRIs must match the BDR Profile of ABIS' proscribed pattern pattern of https://linked.data.gov.au/dataset/bdr/{UUID}/ + supplier pattern" ;
    sh:pattern "^https://linked\\.data\\.gov\\.au/dataset/bdr/[0-9a-f]{8}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{4}-?[0-9a-f]{12}/.+" ;
    sh:targetClass tern:Observation ;
    schema:name "Observation IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

:shape-07
    a sh:NodeShape ;
    sh:message "Agent (Person and Organization) IRIs must match the BDR Profile of ABIS' proscribed pattern which includes linked.data.gov.au" ;
    sh:pattern "linked\\.data\\.gov\\.au" ;
    sh:targetClass
        schema:Organization ,
        schema:Person ;
    schema:name "Agent IRI Pattern" ;
    rdfs:isDefinedBy ds: ;
.

abisv:shape-01
    a sh:NodeShape ;
    sh:property
        [
            sh:class tern:Observation ;
            sh:minCount 1 ;
            sh:path sosa:hasMember ;
        ] ;
    sh:targetClass tern:ObservationCollection ;
    sh:message "The Observation Collection has less than one member Observation" ;
    rdfs:isDefinedBy abisv: ;
    schema:name "Observation Collection members" ; 
.

<https://linked.data.gov.au/org/bdr-team>
    a schema:Organization ;
    schema:name "BDR Team" ;
    schema:url "https://bdr.gov.au/"^^xsd:anyURI ;
.

<https://linked.data.gov.au/org/dcceew>
    a schema:Organization ;
    schema:name "Department of Climate Change, Energy, the Environment and Water" ;
    schema:url "https://www.dcceew.gov.au"^^xsd:anyURI ;
.
 