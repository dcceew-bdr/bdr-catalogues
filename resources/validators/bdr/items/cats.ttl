PREFIX : <https://linked.data.gov.au/dataset/bdr/validator/>
PREFIX dash: <http://datashapes.org/dash#>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX reg: <http://purl.org/linked-data/registry#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://linked.data.gov.au/org/dcceew> a schema:Organization ;
schema:name "Department of Climate Change, Energy, the Environment and Water" ;
schema:url "https://www.dcceew.gov.au"^^xsd:anyURI .

<https://linked.data.gov.au/def/bdr-pr/cats/validator>
    a owl:Ontology ;
    owl:versionIRI :1.0 ;
    owl:versionInfo "1.0 First version" ;
    schema:creator <https://linked.data.gov.au/org/dcceew> ;
    schema:dateCreated "2025-08-01"^^xsd:date ;
    schema:dateModified "2026-04-2"^^xsd:date ;
    skos:historyNote "Updated to conform with ValPub validator" ; 
    schema:description "SHACL validator for catalogues used by the Biodiversity Data Repository"@en ;
    schema:name "BDR Catalogues Validator"@en ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    schema:codeRepository "https://github.com/dcceew-bdr/bdr-catalogues"^^xsd:anyURI ;
    schema:copyrightYear "2026"^^xsd:gYear ;
    schema:copyrightHolder <https://linked.data.gov.au/org/dcceew> ;
    schema:copyrightNotice "© Department of Climate Change, Energy, the Environment and Water" ;
.

:ns-01
    a sh:NodeShape ;
    sh:targetClass schema:DataCatalog ;
    sh:property
        :p-01 ,
        :p-02 ,
        :p-03 ,
        :p-04 ,
        :item-classes ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    schema:description "This NodeShape defines all Property Shapes targeting a DataCatalog" ; 
    schema:name "DataCatalog Property Shapes" ;
.

:p-01
    a sh:PropertyShape ;
    sh:path schema:name ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    sh:message "A DataCatalog SHALL have exactly one name, indicated with schema:name, with datatype xsd:string" ;
    schema:name "Shape Name" ;
.

:p-02
    a sh:PropertyShape ;
    sh:path schema:description ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    sh:message "A DataCatalog SHALL have exactly one description, indicated with schema:description, with datatype xsd:string" ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    schema:name "Shape Description" ;
.

:p-03
    a sh:PropertyShape ;
    sh:path schema:dateCreated ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:date ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    sh:message "A DataCatalog SHALL have exactly one creation date, indicated with schema:dateCreated, with datatype xsd:date" ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    schema:name "Shape Date Created" ;
.

:p-04
    a sh:PropertyShape ;
    sh:path schema:dateModified ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:date ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    sh:message "A DataCatalog SHALL have exactly one modification date, indicated with schema:dateModified, with datatype xsd:date" ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    schema:name "Shape Date Modified" ;
.

:item-classes
    a sh:PropertyShape ;
    sh:path schema:hasPart ;
    #sh:or (
    #    [ sh:class schema:DataCatalog ]
    #    [ sh:class schema:Dataset ]
    #    [ sh:class owl:Ontology ]
    #) ;
    rdfs:isDefinedBy <https://linked.data.gov.au/def/bdr-pr/cats/validator> ;
    sh:message "A validator, typed as either a schema:DataCatalog, schema:Dataset and/or owl:Ontology, SHOULD indicate member shapes with the schema:hasPart predicate" ;
    skos:historyNote "Defined here for the first time by the BDR Catalogues Validator" ;
    schema:name "Shape Has Part" ;
.