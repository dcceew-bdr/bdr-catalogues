cs:
    a skos:ConceptScheme ;
    skos:definition "Vocabulary of types for TaxonNameUsage instances in the NSL, as used in the BDR."@en ;
    skos:historyNote "This vocabulary was developed by the BDR team for the use in the NSL integration within the BDR." ;
    skos:scopeNote "This is used the for soft-typing instances of TaxonNameUsage via the schema:additionalType property." ;
    skos:prefLabel "NSL TaxonNameUsage Types"@en ;
    schema:creator <https://linked.data.gov.au/org/dcceew> ;
    schema:dateCreated "2025-05-20"^^xsd:date ;
    schema:dateModified "2026-07-09"^^xsd:date ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    skos:hasTopConcept
        :valid-name ,
        :alternative-name ,
        :synonym ,
        :replacement-name ,
        :secondary-reference ,
        :orthographic-variant ,
        :basionym ,
        :comb-nov ,
        :isonym ,
        :tax-nov ,
        :autonym ,
        :primary-reference ,
        :nom-nov ,
        :stat-nov ;
    schema:status status:stable ;
    schema:version "1" ;
.
